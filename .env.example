# =============================================================================
# Groq (Phase 2+) — LLM for RAG answers
# =============================================================================
# You need this only when running Phase 2 chat (`python -m mfr_phase2`).
# Phase 1 indexing (`python -m mfr_phase1`) uses local embeddings — no API key.
GROQ_API_KEY=

# Groq OpenAI-compatible chat model (see https://console.groq.com/docs/models )
GROQ_MODEL=llama-3.1-8b-instant

# Optional override (default: Groq OpenAI-compatible base URL)
# GROQ_API_BASE=https://api.groq.com/openai/v1

# =============================================================================
# Shared: Chroma + embeddings (Phase 1 index / Phase 2 retrieval)
# =============================================================================
CHROMA_PATH=./chroma_data
CHROMA_COLLECTION=mutual_fund_faq_groww_v1
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# =============================================================================
# Phase 3 — Refusal education links (AMFI / SEBI)
# =============================================================================
# REFUSAL_EDUCATION_MODE: amfi | sebi | alternate (default: pick AMFI or SEBI from query hash)
REFUSAL_EDUCATION_MODE=alternate
# SEBI_INVESTOR_URL=https://investor.sebi.gov.in/
# AMFI_INVESTOR_EDUCATION_URL=https://www.amfiindia.com/investor/knowledge-center

# =============================================================================
# Phase 4 — API + UI
# =============================================================================
# API_HOST=127.0.0.1
# API_PORT=8000
# THREAD_DB_PATH=./data/threads.sqlite3

# =============================================================================
# Phase 5 — Eval / hybrid (optional)
# =============================================================================
# Install lexical optional: pip install -e ".[phase5]"
# No required env vars; uses CHROMA_* and GROQ_* for full eval.
